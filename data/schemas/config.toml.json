{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "config.toml",
	"properties": {
		"world": {
			"properties": {
				"name": {
					"type": "string"
				}
			},
			"required": ["name"]
		},
		"server": {
			"properties": {
				"port": {
					"type": "number"
				}
			},
			"required": ["port"]
		}
	},
	"required": ["world", "server"]
}
